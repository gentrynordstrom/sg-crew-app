# --- Database (Supabase Postgres) ---
# Pooled connection for the app at runtime
DATABASE_URL="postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations / db push
DIRECT_URL="postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Auth ---
# 32+ char random string used to sign session JWTs (HS256 via jose)
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string"

# --- Bootstrap admin (used by prisma db seed) ---
ADMIN_NAME="Gentry Nordstrom"
# 10-digit US phone; PIN is auto-derived from the last 4 digits unless ADMIN_PIN is set
ADMIN_PHONE="5555555555"
# Optional: if set, overrides the derived PIN. Must be exactly 4 digits.
# ADMIN_PIN="1234"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
